<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TapataktSheduler.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TapataktSheduler"
    xmlns:views="clr-namespace:TapataktSheduler.Views">

    <!--
        Shell определяет высокоуровневую навигацию приложения.
        Каждая страница регистрируется под своим маршрутом для использования в NavigationService.
    -->

    <ShellContent
        Title="Главное меню"
        ContentTemplate="{DataTemplate views:MainMenuPage}"
        Route="MainMenu" />

</Shell>
