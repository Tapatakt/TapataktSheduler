<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TapataktSheduler.Views.DayTypeEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:TapataktSheduler.Models"
    xmlns:vm="clr-namespace:TapataktSheduler.ViewModels"
    Title="Редактирование типа дня">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label FontAttributes="Bold" FontSize="18" Text="Название типа дня" />
            <Entry x:Name="NameEntry" FontSize="18" Text="{Binding Name}" />

            <Button
                BackgroundColor="Red"
                Command="{Binding DeleteCommand}"
                FontAttributes="Bold"
                FontSize="18"
                Text="Удалить"
                TextColor="White" />

            <Label
                Margin="0,10,0,0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Привязанные дела" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AttachedTasks}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskDisplayItem">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Padding="8,4">
                            <Label FontSize="20" Text="{Binding Name}" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DayTypeEditViewModel}}, Path=EditTaskCommand}" CommandParameter="{Binding TaskId}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label
                                Grid.Column="1"
                                FontSize="18"
                                Text="{Binding ReminderTime, StringFormat='{}{0:hh\:mm}'}"
                                TextColor="Gray"
                                VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DayTypeEditViewModel}}, Path=EditTaskTimeCommand}" CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button
                                Grid.Column="2"
                                BackgroundColor="Red"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DayTypeEditViewModel}}, Path=DetachTaskCommand}"
                                CommandParameter="{Binding .}"
                                CornerRadius="4"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="28"
                                Padding="0"
                                Text="✕"
                                TextColor="White"
                                WidthRequest="28" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button
                Command="{Binding AddExistingTaskCommand}"
                FontSize="18"
                Text="Добавить существующее дело" />

            <Button
                Command="{Binding CreateNewTaskCommand}"
                FontSize="18"
                Text="Создать новое дело" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
